{
  "name": "frx-director-mcp",
  "version": "0.3.0",
  "private": true,
  "description": "MCP server for the firefox-reverse browser Agent and fingerprint environments. Delegate to the cheap worker, direct-drive engine tools, or select/create/import isolated FRX_ENV_ID environments.",
  "type": "module",
  "bin": {
    "frx-director-mcp": "dist/index.js"
  },
  "exports": "./dist/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
