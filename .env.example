# ─── frx-director-mcp configuration (copy to .env) ───────────────────────────
# NEVER commit .env or real keys/paths. The MCP server never reads/sends the
# worker model's API key — you configure that ONCE inside the browser's Agent settings.

# Marionette endpoint of a running "Firefox Reverse" instance. The browser MUST be
# launched with BOTH flags so chrome-context privileged JS works:
#   "/Applications/Firefox Reverse.app/Contents/MacOS/firefox" \
#       -marionette -remote-allow-system-access -profile "<YOUR_PROFILE>"
FRX_MARIONETTE_HOST=127.0.0.1
FRX_MARIONETTE_PORT=2828
# Seconds to wait for the marionette port after (auto)launch.
FRX_PORT_WAIT_SEC=90

# Optional auto-launch. If 0, launch Firefox Reverse yourself (above) and the
# server just connects. If 1, the server spawns it for you.
FRX_AUTOLAUNCH=0
FRX_FIREFOX_BIN=/Applications/Firefox Reverse.app/Contents/MacOS/firefox
FRX_PROFILE=

# Path to the SHIPPED AgentPanel.jsx, so the director's system prompt is
# regex-extracted live (SYSTEM + ASSIST_BLOCK / AUTO_BLOCK) and never drifts
# from the UI. If unset, a built-in minimal fallback prompt is used.
FRX_JSX_PROMPT_SRC=

# Worker model. Leave EMPTY to keep whatever the browser is already configured
# with (recommended — respects your in-browser setup). If set, agent_start will
# switch the active provider's model to this. Recommended: deepseek-v4-pro:
#   relay alias e.g.  deepseek-v4-pro        (a 中转站 / relay)
#   direct  e.g.      deepseek-reasoner      (api.deepseek.com)
# pro may drift to plaintext-no-toolcall on long tool loops; the director catches
# it via driftHint/runlog and re-steers with a "call a tool first" instruction.
FRX_DEFAULT_MODEL=

# Root for new session workspaces (the Agent's ledger.md / progress.md / scripts
# live here; the director reads them via agent_read).
# Default: next to the firefox-reverse repo (derived from FRX_JSX_PROMPT_SRC),
#   <repo-parent>/firefox-reverse-ws ; falls back to ~/firefox-reverse-ws.
#   Per-session subdir. Independent of launch cwd.
FRX_WORKSPACE_ROOT=

# Where per-session convo.json + turnlog NDJSON are stored.
# Default: ~/.frx-director-mcp/data
FRX_DATA_DIR=
